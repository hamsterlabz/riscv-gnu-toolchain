diff --git a/gas/config/tc-riscv.c b/gas/config/tc-riscv.c
index 6bcf5383..d202dad3 100644
--- a/gas/config/tc-riscv.c
+++ b/gas/config/tc-riscv.c
@@ -4394,6 +4394,84 @@ riscv_ip_hardcode (char *str,
   return NULL;
 }
 
+/* The `fun` extension's ptr/eptr/combi atoms are 32-bit DATA words whose low
+   two bits are not 0b11, so they are not RISC-V instructions and cannot live
+   in the opcode table.  Emit them directly via the data path.  Returns true
+   if STR was one of these directives.  */
+static bool
+riscv_fun_pseudo (char *str)
+{
+  char *p = str;
+  expressionS ex;
+
+  while (*p == ' ' || *p == '\t')
+    p++;
+
+  if (!strncmp (p, "fn.link", 7) && (p[7] == ' ' || p[7] == '\t'))
+    {
+      /* fn.link sym  ->  .word sym   (ptr: 4-byte-aligned address, low2=00) */
+      my_getExpression (&ex, p + 7, false);
+      riscv_mapping_state (MAP_INSN, 0, false);
+      emit_expr (&ex, 4);
+      return true;
+    }
+  if (!strncmp (p, "fn.elink", 8) && (p[8] == ' ' || p[8] == '\t'))
+    {
+      /* fn.elink sym  ->  .word sym+1  (eptr = ptr|1 = address+1, low2=01) */
+      my_getExpression (&ex, p + 8, false);
+      ex.X_add_number += 1;
+      riscv_mapping_state (MAP_INSN, 0, false);
+      emit_expr (&ex, 4);
+      return true;
+    }
+  if (!strncmp (p, "fn.combi.t", 10))
+    {
+      /* fn.combi.t<type> <arity>, [<a0>,<a1>,<a2>,<a3>,<a4>,<a5>]  ->  a .word
+	 with 0x2 | type[10:4] | arity[13:11] | args[31:14] (3 bits each).  */
+      char *q = p + 10;
+      offsetT type, arity, args[6];
+      int i;
+      valueT w;
+
+      type = strtol (q, &q, 10);
+      while (*q == ' ' || *q == '\t') q++;
+      my_getExpression (&ex, q, false);
+      if (ex.X_op != O_constant)
+	{ as_bad (_("fn.combi: arity must be a constant")); return true; }
+      arity = ex.X_add_number;
+      q = expr_parse_end;
+      while (*q == ' ' || *q == '\t') q++;
+      if (*q++ != ',') { as_bad (_("fn.combi: expected `,'")); return true; }
+      while (*q == ' ' || *q == '\t') q++;
+      if (*q++ != '[') { as_bad (_("fn.combi: expected `['")); return true; }
+      for (i = 0; i < 6; i++)
+	{
+	  while (*q == ' ' || *q == '\t') q++;
+	  my_getExpression (&ex, q, false);
+	  if (ex.X_op != O_constant)
+	    { as_bad (_("fn.combi: args must be constants")); return true; }
+	  args[i] = ex.X_add_number;
+	  q = expr_parse_end;
+	  while (*q == ' ' || *q == '\t') q++;
+	  if (i < 5 && *q++ != ',')
+	    { as_bad (_("fn.combi: expected 6 args `[a0,..,a5]'")); return true; }
+	}
+      if (*q != ']') { as_bad (_("fn.combi: expected `]'")); return true; }
+      /* opcode[3:0]=0x2 | type[10:4] (7 bits, T0..T64) | arity[13:11] | args[31:14] */
+      w = 0x2 | ((valueT) (type & 0x7f) << 4) | ((valueT) (arity & 0x7) << 11);
+      for (i = 0; i < 6; i++)
+	w |= (valueT) (args[i] & 0x7) << (14 + 3 * i);
+      ex.X_op = O_constant;
+      ex.X_add_symbol = NULL;
+      ex.X_op_symbol = NULL;
+      ex.X_add_number = w;
+      riscv_mapping_state (MAP_INSN, 0, false);
+      emit_expr (&ex, 4);
+      return true;
+    }
+  return false;
+}
+
 void
 md_assemble (char *str)
 {
@@ -4401,6 +4479,9 @@ md_assemble (char *str)
   expressionS imm_expr;
   bfd_reloc_code_real_type imm_reloc = BFD_RELOC_UNUSED;
 
+  if (riscv_fun_pseudo (str))
+    return;
+
   /* The architecture and privileged elf attributes should be set
      before assembling.  */
   if (!start_assemble)
diff --git a/include/opcode/riscv-opc.h b/include/opcode/riscv-opc.h
index 6f2775c6..fa177758 100644
--- a/include/opcode/riscv-opc.h
+++ b/include/opcode/riscv-opc.h
@@ -4327,7 +4327,68 @@
 /* Ssqosid CSR addresses.  */
 #define CSR_SRMCFG 0x181
 #endif /* RISCV_ENCODING_H */
+/* fun extension (xfun): combinator graph-reduction instructions on the
+   RISC-V custom opcodes (0x0b, 0x5b, 0x7b) plus the low-2-bit-tagged graph
+   data words.  Encodings mirror blackbird-f (rtl/core/fun/reduction_unit.sv,
+   rtl/core/riscv_core.sv host ops, and Model/RvRef.hs).  */
+
+/* Opcode 0x5b (SYSTEM-custom), selected by funct3: the graph reducer's
+   terminators (Y/seq/force/box) plus the host value-movement ops
+   (tor/update/databox).  The terminators read their operands from the
+   reduction spine, so they take no register fields.  */
+#define MATCH_FN_Y	0x0000005b	/* funct3 0: Y (fixpoint knot).  */
+#define MASK_FN_Y	0xffffffff
+#define MATCH_FN_SEQ	0x0000105b	/* funct3 1: seq.  */
+#define MASK_FN_SEQ	0xffffffff
+#define MATCH_FN_TOR	0x0000205b	/* funct3 2: pop spine, rd <- mem[top+4].  */
+#define MASK_FN_TOR	0xfffff07f
+#define MATCH_FN_UPDATE	0x0000305b	/* funct3 3: mem[spine top] <- R[rs2]|1, pop.  */
+#define MASK_FN_UPDATE	0xfe0fffff
+#define MATCH_FN_FORCE	0x0000505b	/* funct3 5: force.  */
+#define MASK_FN_FORCE	0xffffffff
+#define MATCH_FN_BOX	0x0000605b	/* funct3 6: box.  */
+#define MASK_FN_BOX	0xffffffff
+#define MATCH_FN_DATABOX	0x0000705b	/* funct3 7: box R[rs1], rd <- box ptr.  */
+#define MASK_FN_DATABOX	0xfff0707f
+/* Opcode 0x0b: enter -- pop the spine, resume at the popped continuation.  */
+#define MATCH_FN_ENTER	0x0000000b
+#define MASK_FN_ENTER	0xffffffff
+/* Opcode 0x7b: explicit recursion schemes, selected by funct3.  */
+#define MATCH_FN_CATA	0x0000007b	/* funct3 0: catamorphism.  */
+#define MASK_FN_CATA	0xffffffff
+#define MATCH_FN_ANA	0x0000107b	/* funct3 1: anamorphism.  */
+#define MASK_FN_ANA	0xffffffff
+#define MATCH_FN_PARA	0x0000207b	/* funct3 2: paramorphism.  */
+#define MASK_FN_PARA	0xffffffff
+#define MATCH_FN_HYLO	0x0000307b	/* funct3 3: hylomorphism.  */
+#define MASK_FN_HYLO	0xffffffff
+/* Graph data words (not instructions -- their low two bits are never 0b11).
+   fn.link: a pointer cell (low2 00).  fn.elink: an indirection (low2 01).
+   fn.combi: a combinator node (low3 010) with type[10:4], arity[13:11] and
+   up to six 3-bit arg selectors at [14+3k+:3].  */
+#define MATCH_FN_LINK	0x00000000
+#define MASK_FN_LINK	0x00000003
+#define MATCH_FN_ELINK	0x00000001
+#define MASK_FN_ELINK	0x00000003
+#define MATCH_FN_COMBI	0x00000002
+#define MASK_FN_COMBI	0x00000007
+
 #ifdef DECLARE_INSN
+DECLARE_INSN(fn_y, MATCH_FN_Y, MASK_FN_Y)
+DECLARE_INSN(fn_seq, MATCH_FN_SEQ, MASK_FN_SEQ)
+DECLARE_INSN(fn_tor, MATCH_FN_TOR, MASK_FN_TOR)
+DECLARE_INSN(fn_update, MATCH_FN_UPDATE, MASK_FN_UPDATE)
+DECLARE_INSN(fn_force, MATCH_FN_FORCE, MASK_FN_FORCE)
+DECLARE_INSN(fn_box, MATCH_FN_BOX, MASK_FN_BOX)
+DECLARE_INSN(fn_databox, MATCH_FN_DATABOX, MASK_FN_DATABOX)
+DECLARE_INSN(fn_enter, MATCH_FN_ENTER, MASK_FN_ENTER)
+DECLARE_INSN(fn_cata, MATCH_FN_CATA, MASK_FN_CATA)
+DECLARE_INSN(fn_ana, MATCH_FN_ANA, MASK_FN_ANA)
+DECLARE_INSN(fn_para, MATCH_FN_PARA, MASK_FN_PARA)
+DECLARE_INSN(fn_hylo, MATCH_FN_HYLO, MASK_FN_HYLO)
+DECLARE_INSN(fn_link, MATCH_FN_LINK, MASK_FN_LINK)
+DECLARE_INSN(fn_elink, MATCH_FN_ELINK, MASK_FN_ELINK)
+DECLARE_INSN(fn_combi, MATCH_FN_COMBI, MASK_FN_COMBI)
 DECLARE_INSN(slli_rv32, MATCH_SLLI_RV32, MASK_SLLI_RV32)
 DECLARE_INSN(srli_rv32, MATCH_SRLI_RV32, MASK_SRLI_RV32)
 DECLARE_INSN(srai_rv32, MATCH_SRAI_RV32, MASK_SRAI_RV32)
