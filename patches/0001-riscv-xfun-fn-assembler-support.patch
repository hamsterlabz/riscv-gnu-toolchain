diff --git a/opcodes/riscv-dis.c b/opcodes/riscv-dis.c
index 03c8cf1e..669c932e 100644
--- a/opcodes/riscv-dis.c
+++ b/opcodes/riscv-dis.c
@@ -1344,6 +1344,58 @@ riscv_data_length (bfd_vma memaddr,
   return length;
 }
 
+/* Disassemble a `fun` extension DATA word (low two bits != 0b11, so not a
+   RISC-V instruction): ptr -> fn.link, eptr -> fn.elink, combi -> fn.combi,
+   int -> .word.  Always 4 bytes.  */
+
+static int
+riscv_disassemble_fun_data (bfd_vma memaddr ATTRIBUTE_UNUSED,
+			    insn_t insn,
+			    const bfd_byte *packet ATTRIBUTE_UNUSED,
+			    disassemble_info *info)
+{
+  unsigned int w = (unsigned int) insn;
+  void *s = info->stream;
+  info->bytes_per_chunk = 4;
+  info->bytes_per_line = 8;
+  switch (w & 0x3)
+    {
+    case 0x0:	/* ptr */
+      (*info->fprintf_styled_func) (s, dis_style_mnemonic, "fn.link");
+      (*info->fprintf_styled_func) (s, dis_style_text, "\t");
+      (*info->fprintf_styled_func) (s, dis_style_address, "0x%x", w);
+      break;
+    case 0x1:	/* eptr */
+      (*info->fprintf_styled_func) (s, dis_style_mnemonic, "fn.elink");
+      (*info->fprintf_styled_func) (s, dis_style_text, "\t");
+      (*info->fprintf_styled_func) (s, dis_style_address, "0x%x", w & ~3u);
+      break;
+    default:	/* low2 == 0b10 */
+      if ((w & 0x4) == 0)	/* combi:  fn.combi.t<type> <arity>, [a0..a5] */
+	{
+	  (*info->fprintf_styled_func) (s, dis_style_mnemonic, "fn.combi.t%u",
+					(w >> 4) & 0x7f);
+	  (*info->fprintf_styled_func)
+	    (s, dis_style_text, "\t%u, [%u,%u,%u,%u,%u,%u]",
+	     (w >> 11) & 0x7,
+	     (w >> 14) & 0x7, (w >> 17) & 0x7, (w >> 20) & 0x7,
+	     (w >> 23) & 0x7, (w >> 26) & 0x7, (w >> 29) & 0x7);
+	}
+      else			/* int literal */
+	{
+	  int v = (int) ((w >> 3) & 0x1fffffff);
+	  if (v >= 0x10000000)
+	    v -= 0x20000000;
+	  (*info->fprintf_styled_func) (s, dis_style_assembler_directive, ".word");
+	  (*info->fprintf_styled_func) (s, dis_style_text, "\t");
+	  (*info->fprintf_styled_func) (s, dis_style_immediate, "0x%08x", w);
+	  (*info->fprintf_styled_func) (s, dis_style_comment_start, "\t# int %d", v);
+	}
+      break;
+    }
+  return 4;
+}
+
 /* Dump the data contents.  */
 
 static int
@@ -1557,6 +1609,16 @@ print_insn_riscv (bfd_vma memaddr, struct disassemble_info *info)
       insn = (insn_t) bfd_getl16 (packet);
       dump_size = riscv_insn_length (insn);
       riscv_disassembler = riscv_disassemble_insn;
+      /* `fun` extension: ptr/eptr/combi/int are 32-bit DATA words (low2 != 0b11
+	 so not real instructions).  Decode them as fun directives.  */
+      if ((insn & 0x3) != 0x3
+	  && riscv_subset_supports
+	       (&((struct riscv_private_data *) info->private_data)->riscv_rps_dis,
+		"xfun"))
+	{
+	  dump_size = 4;
+	  riscv_disassembler = riscv_disassemble_fun_data;
+	}
     }
 
   bytes_fetched = fetch_insn (memaddr, packet, dump_size, info, &status);
